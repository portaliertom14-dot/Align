# Supabase — PROD : utiliser le MÊME projet que celui où les utilisateurs ont leurs données (profils, onboarding_completed).
# Si EXPO_PUBLIC_SUPABASE_URL/ANON_KEY en prod pointent vers un autre projet, le fetch profile échoue ou retourne une autre DB → redirection vers onboarding.
EXPO_PUBLIC_SUPABASE_URL=https://yuqybxhqhgmeqmcpgtvw.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_9ycoZ9z7IF1SByxg-oT6XA_3H07NgND

# Scripts ESCO (ingest + embed) : Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# IA OpenAI (way + ESCO) — https://platform.openai.com/api-keys
# Scripts : OPENAI_API_KEY ou EXPO_PUBLIC_OPENAI_API_KEY
# Edge Functions : OPENAI_API_KEY (Supabase Dashboard → Edge Functions → Secrets)
# Si absent : l'app utilise des fallbacks basiques (secteurs/métiers limités)
EXPO_PUBLIC_OPENAI_API_KEY=sk-votre_cle_api_ici

# Domaine web — getWebBaseUrl() / reset password (PROD = https://align-app.fr)
EXPO_PUBLIC_WEB_URL_PROD=https://align-app.fr
EXPO_PUBLIC_WEB_URL_PREVIEW=
EXPO_PUBLIC_WEB_URL_DEV=http://localhost:5173

# Contact support (Paramètres → Contact support)
EXPO_PUBLIC_SUPPORT_EMAIL=align.app.contact@gmail.com

# Microsoft Clarity (analytics) — à définir UNIQUEMENT en production, pas en dev
# EXPO_PUBLIC_CLARITY_PROJECT_ID=

# Feature flag paywall — "true" = paywall actif, "false" = paywall désactivé (flux gratuit).
# Non défini : en dev = actif, en prod = désactivé.
# Utiliser EXPO_PUBLIC_PAYWALL_ENABLED ou NEXT_PUBLIC_PAYWALL_ENABLED.
# EXPO_PUBLIC_PAYWALL_ENABLED=true

# Stripe — clé PUBLISHABLE uniquement (pour affichage / vérification mode test).
# Le frontend redirige vers session.url renvoyé par le backend ; il n'utilise pas loadStripe.
# Pour les cartes de test (ex: 4242 4242 4242 4242), le BACKEND doit utiliser une clé TEST :
# Supabase → Edge Functions → Secrets → STRIPE_SECRET_KEY=sk_test_...
# (Si vous voyez "carte refusée car vous êtes en production", c'est que STRIPE_SECRET_KEY est en sk_live_.)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX

# Dev uniquement — compte test pour le menu Dev (skip parcours + tester modules).
# Créer un compte dans l’app (ou Supabase Auth), terminer l’onboarding une fois, puis mettre email/mdp ici.
# En prod ces variables ne sont pas lues.
# EXPO_PUBLIC_DEV_TEST_EMAIL=test@example.com
# EXPO_PUBLIC_DEV_TEST_PASSWORD=ton_mot_de_passe

# IMPORTANT : Ne jamais mettre de clé secrète (OpenAI, Stripe sk_..., etc.) en EXPO_PUBLIC_*.
# Les clés API sensibles doivent rester côté Edge Functions (Supabase Secrets).
